/**
 * Favorites Paywall Modal
 *
 * Handles favorites button interception and modal display for members-only saving
 *
 * @package AutostraddleFeatures
 * @since 1.0.0
 */

console.log("Favorites Paywall Modal: Script loaded");

(function ($) {
  "use strict";

  /**
   * Initialize paywall functionality
   */
  function init() {
    console.log("Favorites Paywall: Init function called");

    // Check if data object exists
    if (typeof favoritesPaywallData === "undefined") {
      console.error("Favorites Paywall: favoritesPaywallData is not defined");
      return;
    }

    console.log("Favorites Paywall: Initializing", favoritesPaywallData);

    // Set up modal close handlers (always needed)
    setupModalHandlers();

    // Check if user already has access - if so, no need to block anything
    if (favoritesPaywallData.hasAccess) {
      console.log("Favorites Paywall: User has access, paywall disabled");
      return;
    }

    console.log(
      "Favorites Paywall: User does not have access - attaching handlers"
    );

    // Intercept favorites button clicks - using capture phase for dynamically added buttons
    attachCapturePhaseHandler();

    // Also attach standard delegated handler as backup
    attachPaywallHandlers();

    // Attach handler for bookmarks link in header
    attachBookmarksLinkHandler();

    // Also listen for the favorites plugin's authentication requirement event (for logged out users)
    $(document).on("favorites-require-authentication", function (e, data) {
      console.log(
        "Favorites Paywall: Authentication required event triggered",
        data
      );
      showModal();
    });
  }

  /**
   * Attach capture phase handler to intercept clicks before Favorites plugin
   * This is needed because dynamically injected buttons might have handlers
   * that stop propagation before our delegated handler sees the event
   */
  function attachCapturePhaseHandler() {
    console.log("Favorites Paywall: Attaching capture phase handler");

    // Use native addEventListener with capture: true to intercept early
    document.addEventListener(
      "click",
      function (e) {
        // Check if the clicked element is a favorites button or is inside one
        var target = e.target;
        var button = null;

        // Check if target itself is the button
        if (
          target.classList &&
          (target.classList.contains("simplefavorite-button") ||
            target.hasAttribute("data-postid"))
        ) {
          button = target;
        } else if (target.closest) {
          // Otherwise check if it's inside a button
          button =
            target.closest(".simplefavorite-button") ||
            target.closest("button[data-postid]");
        }

        if (!button) {
          return; // Not a favorites button
        }

        console.log(
          "Favorites Paywall: Capture phase - button clicked!",
          button
        );

        var $button = $(button);
        var isActive = $button.hasClass("active");

        console.log("Favorites Paywall: Capture phase - button state", {
          element: button,
          isActive: isActive,
          hasAccess: favoritesPaywallData.hasAccess,
          isLoggedIn: favoritesPaywallData.isLoggedIn,
          classes: button.className,
        });

        // Only block when adding to favorites (not removing)
        if (!isActive && !favoritesPaywallData.hasAccess) {
          console.log(
            "Favorites Paywall: CAPTURE PHASE BLOCKING - Showing modal"
          );
          e.preventDefault();
          e.stopPropagation();
          e.stopImmediatePropagation();
          showModal();
        }
      },
      true // Use capture phase - this runs BEFORE the Favorites plugin's handler
    );

    console.log("Favorites Paywall: Capture phase handler attached");
  }

  /**
   * Attach paywall handlers to favorites buttons (delegated, as backup)
   */
  function attachPaywallHandlers() {
    console.log("Favorites Paywall: Attaching delegated click handlers");

    // Intercept all favorites button clicks using event delegation
    $(document).on(
      "click.favoritespaywall",
      ".simplefavorite-button, button[data-postid]",
      function (e) {
        console.log(
          "Favorites Paywall: Button clicked (bubbling phase)!",
          this
        );

        var $button = $(this);
        var isActive = $button.hasClass("active");

        console.log("Favorites Paywall: Bubbling phase - button state", {
          element: this,
          isActive: isActive,
          hasAccess: favoritesPaywallData.hasAccess,
          isLoggedIn: favoritesPaywallData.isLoggedIn,
          classes: $button.attr("class"),
        });

        // Only block when adding to favorites (not removing)
        if (!isActive && !favoritesPaywallData.hasAccess) {
          console.log(
            "Favorites Paywall: BUBBLING PHASE BLOCKING - Showing modal"
          );
          e.preventDefault();
          e.stopImmediatePropagation();
          showModal();
          return false;
        }

        console.log("Favorites Paywall: Allowing click to proceed");
        return true;
      }
    );

    // Log the number of buttons found on initial page load
    setTimeout(function () {
      var buttonCount = $(".simplefavorite-button, button[data-postid]").length;
      console.log(
        "Favorites Paywall: Found " + buttonCount + " favorite buttons on page"
      );
    }, 500);
  }

  /**
   * Attach handler for bookmarks link in header
   */
  function attachBookmarksLinkHandler() {
    console.log("Favorites Paywall: Attaching bookmarks link handler");

    // Intercept clicks on the bookmarks link
    $(document).on("click", "#header-bookmarks-link", function (e) {
      console.log(
        "Favorites Paywall: Bookmarks link clicked",
        favoritesPaywallData
      );

      // If user doesn't have access, show the modal instead of navigating
      if (!favoritesPaywallData.hasAccess) {
        console.log(
          "Favorites Paywall: Blocking bookmarks link - Showing modal"
        );
        e.preventDefault();
        showModal();
        return false;
      }

      console.log("Favorites Paywall: Allowing bookmarks link to proceed");
      return true;
    });
  }

  /**
   * Show the paywall modal
   */
  function showModal() {
    console.log("Favorites Paywall: showModal called");

    var $modal = $("#favorites-paywall-modal");

    if (!$modal.length) {
      console.error("Favorites paywall modal not found in DOM");
      return;
    }

    console.log("Favorites Paywall: Showing modal");

    // Show modal
    $modal.removeClass("hidden").css("display", "");

    // Prevent body scroll
    $("body").addClass("overflow-hidden");

    // Focus trap
    trapFocus($modal);

    // Trigger custom event
    $(document).trigger("favorites-paywall-modal-opened");
  }

  /**
   * Hide the paywall modal
   */
  function hideModal() {
    var $modal = $("#favorites-paywall-modal");

    // Hide modal
    $modal.addClass("hidden").css("display", "none");

    // Restore body scroll
    $("body").removeClass("overflow-hidden");

    // Trigger custom event
    $(document).trigger("favorites-paywall-modal-closed");
  }

  /**
   * Set up modal event handlers
   */
  function setupModalHandlers() {
    var $modal = $("#favorites-paywall-modal");

    if (!$modal.length) {
      console.warn(
        "Favorites Paywall: Modal not found when setting up handlers"
      );
      return;
    }

    console.log("Favorites Paywall: Setting up modal handlers");

    // Close button
    $modal.find(".favorites-paywall-close").on("click", function (e) {
      e.preventDefault();
      hideModal();
    });

    // Close on overlay click
    $modal
      .find(".fixed.inset-0.bg-black, [aria-hidden='true']")
      .on("click", function (e) {
        if (e.target === this) {
          hideModal();
        }
      });

    // Close on ESC key
    $(document).on("keydown", function (e) {
      if (e.key === "Escape" && !$modal.hasClass("hidden")) {
        hideModal();
      }
    });
  }

  /**
   * Trap focus within modal
   *
   * @param {jQuery} $modal Modal element
   */
  function trapFocus($modal) {
    var focusableElements = $modal.find(
      'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
    );
    var firstElement = focusableElements.first();
    var lastElement = focusableElements.last();

    // Focus first element
    firstElement.focus();

    // Trap focus
    $modal.off("keydown.focustrap").on("keydown.focustrap", function (e) {
      if (e.key !== "Tab") {
        return;
      }

      if (e.shiftKey) {
        // Shift + Tab
        if (document.activeElement === firstElement[0]) {
          e.preventDefault();
          lastElement.focus();
        }
      } else {
        // Tab
        if (document.activeElement === lastElement[0]) {
          e.preventDefault();
          firstElement.focus();
        }
      }
    });
  }

  /**
   * Initialize on document ready
   */
  $(document).ready(function () {
    console.log("Favorites Paywall: Document ready, calling init");
    init();
  });
})(jQuery);
