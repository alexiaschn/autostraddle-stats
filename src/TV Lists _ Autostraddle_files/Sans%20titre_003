/**
 * Gravity Forms Paywall Modal
 *
 * Handles form submission interception and modal display for members-only forms
 *
 * @package AutostraddleFeatures
 * @since 1.0.0
 */

(function ($) {
  "use strict";

  /**
   * Initialize paywall functionality
   */
  function init() {
    // Check if user already has access - if so, no need to block anything
    if (gfPaywallData.hasAccess) {
      return;
    }

    // Find all Gravity Forms on the page with paywall enabled
    $('form[data-gf-paywall-enabled="1"]').each(function () {
      var $form = $(this);
      attachPaywallHandlers($form);
    });

    // Set up modal close handlers
    setupModalHandlers();
  }

  /**
   * Attach paywall handlers to a form
   *
   * @param {jQuery} $form Form element
   */
  function attachPaywallHandlers($form) {
    // Intercept form submission
    $form.on("submit.gfpaywall", function (e) {
      // Check if we've already validated
      if ($form.data("gf-paywall-validated")) {
        return true;
      }

      // Only intercept if user doesn't have access
      if (!gfPaywallData.hasAccess) {
        e.preventDefault();
        e.stopImmediatePropagation();
        showModal($form);
        return false;
      }

      return true;
    });

    // Intercept button clicks
    $form
      .find('.gform_button, .gform_next_button, input[type="submit"]')
      .on("click.gfpaywall", function (e) {
        if (!gfPaywallData.hasAccess && !$form.data("gf-paywall-validated")) {
          e.preventDefault();
          e.stopImmediatePropagation();
          showModal($form);
          return false;
        }
      });
  }

  /**
   * Show the paywall modal
   *
   * @param {jQuery} $form The form that triggered the modal
   */
  function showModal($form) {
    var $modal = $("#gf-paywall-modal");

    if (!$modal.length) {
      console.error("Paywall modal not found");
      return;
    }

    // Get form name and replace placeholder in modal content
    var formName = $form.attr("data-gf-paywall-form-name") || "this form";
    var contentTemplate = gfPaywallData.modalContentTemplate || "";
    var modalContent = contentTemplate.replace(/\{form_name\}/g, formName);

    // Update modal content
    var $modalContent = $modal.find("#gf-paywall-modal-content");
    if ($modalContent.length) {
      $modalContent.text(modalContent);
    }

    // Show modal
    $modal.removeClass("hidden");

    // Prevent body scroll
    $("body").addClass("overflow-hidden");

    // Focus trap
    trapFocus($modal);

    // Trigger custom event
    $(document).trigger("gf-paywall-modal-opened", [formName]);
  }

  /**
   * Hide the paywall modal
   */
  function hideModal() {
    var $modal = $("#gf-paywall-modal");

    // Hide modal
    $modal.addClass("hidden");

    // Restore body scroll
    $("body").removeClass("overflow-hidden");

    // Trigger custom event
    $(document).trigger("gf-paywall-modal-closed");
  }

  /**
   * Set up modal event handlers
   */
  function setupModalHandlers() {
    var $modal = $("#gf-paywall-modal");

    if (!$modal.length) {
      return;
    }

    // Close button
    $modal.find(".gf-paywall-close").on("click", function (e) {
      e.preventDefault();
      hideModal();
    });

    // Close on overlay click
    $modal.find(".fixed.inset-0.bg-black").on("click", function (e) {
      if (e.target === this) {
        hideModal();
      }
    });

    // Close on ESC key
    $(document).on("keydown", function (e) {
      if (e.key === "Escape" && !$modal.hasClass("hidden")) {
        hideModal();
      }
    });
  }

  /**
   * Trap focus within modal
   *
   * @param {jQuery} $modal Modal element
   */
  function trapFocus($modal) {
    var focusableElements = $modal.find(
      'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
    );
    var firstElement = focusableElements.first();
    var lastElement = focusableElements.last();

    // Focus first element
    firstElement.focus();

    // Trap focus
    $modal.off("keydown.focustrap").on("keydown.focustrap", function (e) {
      if (e.key !== "Tab") {
        return;
      }

      if (e.shiftKey) {
        // Shift + Tab
        if (document.activeElement === firstElement[0]) {
          e.preventDefault();
          lastElement.focus();
        }
      } else {
        // Tab
        if (document.activeElement === lastElement[0]) {
          e.preventDefault();
          firstElement.focus();
        }
      }
    });
  }

  /**
   * Initialize on document ready
   */
  $(document).ready(function () {
    init();
  });

  /**
   * Re-initialize after AJAX content load (for multi-page forms)
   */
  $(document).on("gform_post_render", function (event, formId, currentPage) {
    // Only re-initialize if user doesn't have access
    if (gfPaywallData.hasAccess) {
      return;
    }

    // Re-attach handlers to the form if it has paywall enabled
    var $form = $("#gform_" + formId);
    if ($form.attr("data-gf-paywall-enabled") === "1") {
      // Remove old handlers first
      $form.off(".gfpaywall");
      $form
        .find('.gform_button, .gform_next_button, input[type="submit"]')
        .off(".gfpaywall");

      // Re-attach
      attachPaywallHandlers($form);
    }
  });
})(jQuery);
